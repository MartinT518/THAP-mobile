# Copy to `.env` and fill in values.
# Where each value comes from: docs/03-development/ENVIRONMENT_VARIABLE_SOURCES.md
# Local install: LOCAL_SETUP.md

DATABASE_URL=mysql://user:password@127.0.0.1:3306/thap
JWT_SECRET=change-me-to-a-long-random-string

# OAuth: backend must expose the WebDev-style token exchange used in server/_core/sdk.ts
OAUTH_SERVER_URL=
VITE_OAUTH_PORTAL_URL=
# Client id for the login redirect (Vite exposes VITE_* to the browser)
VITE_OAUTH_CLIENT_ID=

# User with this openId gets admin role on first sync
OWNER_OPEN_ID=

VITE_APP_TITLE=Thap

# Optional: one base URL + API key for server features (OpenAI-compatible chat at
# /v1/chat/completions, storage proxy, maps API, notifications, etc.)
THAP_SERVICES_BASE_URL=
THAP_SERVICES_API_KEY=

# Optional: browser Google Maps loader via your maps proxy
VITE_MAPS_PROXY_BASE_URL=
VITE_MAPS_PROXY_API_KEY=
