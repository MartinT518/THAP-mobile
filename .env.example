# Copy to `.env` and fill in values.
# Where each value comes from: docs/03-development/ENVIRONMENT_VARIABLE_SOURCES.md
# Local install: LOCAL_SETUP.md

DATABASE_URL=mysql://user:password@127.0.0.1:3306/thap
JWT_SECRET=change-me-to-a-long-random-string

# Google Sign-In: create credentials at https://console.cloud.google.com/apis/credentials
# VITE_ prefix exposes to the browser for the GIS script; server also reads it for token verification.
VITE_GOOGLE_CLIENT_ID=

# User with this openId gets admin role on first sync
OWNER_OPEN_ID=

VITE_APP_TITLE=Thap
# PWA / favicon fallback (PNG); SVG is served from /favicon.svg
VITE_APP_LOGO=/icon-192.png

# Local dev: skip OAuth when set (non-production only). User is created if missing.
DEV_AUTH_OPEN_ID=

# Legacy QR deep links (id.tings.info / qr.tings.info): optional v2 API auth if the host requires it
TINGS_API_BASE=https://tingsapi.test.mindworks.ee
TINGS_API_BEARER_TOKEN=

# Icecat Live JSON API (optional product lookup by GTIN/EAN)
ICECAT_SHOPNAME=
ICECAT_API_TOKEN=
# Optional — needed for some image assets
ICECAT_CONTENT_TOKEN=
ICECAT_LANG=EN

# Optional: one base URL + API key for server features (OpenAI-compatible chat at
# /v1/chat/completions, storage proxy, maps API, notifications, etc.)
THAP_SERVICES_BASE_URL=
THAP_SERVICES_API_KEY=

# Optional: browser Google Maps loader via your maps proxy
VITE_MAPS_PROXY_BASE_URL=
VITE_MAPS_PROXY_API_KEY=
